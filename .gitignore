cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
.venv/

# Environment Variables
.env
.env.*

# Flask
instance/
.flaskenv

# Logs
*.log

# Database
*.db
*.sqlite
*.sqlite3

# IDEs
.vscode/
.idea/

# OS Files
.DS_Store
Thumbs.db

# Build
build/
dist/
*.egg-info/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Cache
.cache/

# Jupyter
.ipynb_checkpoints/

# Temporary files
tmp/
temp/
EOF
prompt.txt
prompt.txt
